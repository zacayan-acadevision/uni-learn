<div class="card" style="margin-top:30px;">
  <h3 style="margin-bottom:15px;">🎥 Vídeos Relacionable</h3>
  <div id="video-grid" style="display: flex; flex-wrap: wrap; gap: 15px;">
    <% contributions.contribuciones.filter(c=> c.tipo == "YOUTUBE").forEach(contrib => { %>
      <div class="video-thumb" onclick="playVideo('rzYDWIQh2r4')"
        style="cursor:pointer; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; background: #000; width: 200px;">
        <img src="https://img.youtube.com/vi/rzYDWIQh2r4/mqdefault.jpg" style="width:100%; display:block;">
        <div style="padding: 8px; font-size: 0.8rem; color: #ffffff; text-align:center;">
          <%= contrib.content %>
        </div>
      </div>
      <% }) %>
  </div>
</div>

<div id="main-player-container" class="card"
  style="display:none; padding:0; overflow:hidden; border:none; background:#000; position:fixed; top:50%; left:20%; transform: translateY(-50%); width:60%; height:80vh; z-index:9999;">
  <div style="position: relative; padding-bottom: 56.25%; height: 0;">
    <iframe id="yt-player" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
      src="" frameborder="0" allowfullscreen></iframe>
  </div>
  <div
    style="padding:15px; text-align:right; background:#222; position:absolute; bottom:0; left:0; width:100%; flex-shrink: 0;">
    <button class="btn btn-primary" onclick="closePlayer()"
      style="font-size:0.8rem; color:white;">Cerrar
      Vídeo</button>
  </div>
</div>

<script>
  function playVideo(id) {
    const container = document.getElementById('main-player-container');
    const player = document.getElementById('yt-player');
    player.src = "https://www.youtube.com/embed/" + id + "?autoplay=1";
    container.style.display = 'block';
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  }

  function closePlayer() {
    document.getElementById('main-player-container').style.display = 'none';
    document.getElementById('yt-player').src = '';
  }
</script>