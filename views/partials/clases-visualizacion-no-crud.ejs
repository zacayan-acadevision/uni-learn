<div class="card">
  <h2 style="margin-bottom:15px;">Clases Disponibles</h2>
  <div id="listaClases">

    <% clases.clases.forEach(clase => { %>
    <div class="list-item" data-n="clase <%= clase.id %> <%= clase.titulo %>" id="claseItem<%= clase.id %>">
      <span class="item-text"><strong style="color:var(--primary)">Clase <%= clase.id %>:</strong> <%= clase.titulo %></span>
      <div style="display:flex; gap:5px;">
        <a href="/uni/materia/<%= clases.id%>/clase/<%= clase.id %>" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver Clase</a>
      </div>
    </div>
    <% }) %>
  </div>
</div>