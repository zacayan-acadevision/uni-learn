<div class="card">
  <h3 style="margin-bottom:15px;">💬 Comentarios</h3>
  <div id="comments-list" style="margin-bottom:15px;">
    <p style="font-size:0.85rem; color:#64748b;">No hay comentarios nuevos.</p>
  </div>
  <div style="margin-bottom:15px;">
    <textarea id="comment-input" placeholder="Escribe tu comentario aquí..." rows="3"
      style="width:100%; padding:10px; border:1px solid var(--border); border-radius:6px; resize:vertical; font-family:inherit;">[<% const comentarios = contributions.contribuciones.filter(c=> c.tipo == "COMENTARIO"); %>
<% comentarios.forEach((contrib, index) => { %>
        {"msg":"<%= contrib.content.replace(/"/g, '&quot;') %>"}<% if (index < comentarios.length - 1) { %>,<% } %>
<% }) %>]</textarea>
  </div>
  <div style="display:flex; gap:10px;">
    <button onclick="addComment(<%= claseId %>)"
      style="flex:1; padding:8px 16px; background:var(--accent); color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.9rem;">
      Publicar Comentario
    </button>
    <button onclick="clearComments()"
      style="flex:1; padding:8px 16px; background:#64748b; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.9rem;">
      Limpiar
    </button>
  </div>
</div>

<script>
  function renderExistingComments() {
    const commentInput = document.getElementById('comment-input');
    const commentsList = document.getElementById('comments-list');
    const commentText = commentInput.value.trim();

    if (commentText) {
      try {
        const comments = JSON.parse(commentText);
        if (comments && comments.length > 0) {
          commentsList.innerHTML = '';

          comments.forEach((comment, index) => {
            const now = new Date();
            const timeString = now.toLocaleTimeString('es-ES', {
              hour: '2-digit',
              minute: '2-digit'
            });
            const dateString = now.toLocaleDateString('es-ES', {
              day: '2-digit',
              month: '2-digit',
              year: 'numeric'
            });

            const newComment = document.createElement('div');
            newComment.style.padding = '10px';
            newComment.style.borderBottom = '1px solid var(--border)';
            newComment.style.fontSize = '0.85rem';
            newComment.innerHTML = `
              <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:5px;">
                <strong style="color:var(--accent);">Tú:</strong>
                <div style="display:flex; gap:5px;">
                  <button onclick="editComment(${index})" style="background:none; border:none; color:var(--accent); cursor:pointer; font-size:0.8rem;">✏️ Editar</button>
                  <button onclick="confirmDeleteComment(${index})" style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:0.8rem;">🗑️ Eliminar</button>
                </div>
              </div>
              <div id="comment-text-${index}">${comment.msg}</div>
              <div id="comment-edit-${index}" style="display:none;">
                <textarea id="comment-input-${index}" rows="2" style="width:100%; padding:8px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">${comment.msg}</textarea>
                <div style="margin-top:5px; display:flex; gap:10px;">
                  <button onclick="saveComment(${index})" style="flex:1; padding:6px 12px; background:var(--accent); color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Actualizar</button>
                  <button onclick="cancelEditComment(${index})" style="flex:1; padding:6px 12px; background:#64748b; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Cancelar</button>
                </div>
              </div>
              <div style="margin-top:5px;">
                <span style="color:#64748b; font-size:0.75rem;">${dateString} ${timeString}</span>
              </div>
            `;

            commentsList.appendChild(newComment);
          });
        } else {
          commentsList.innerHTML = '<p style="font-size:0.85rem; color:#64748b;">No hay comentarios nuevos.</p>';
        }
      } catch (error) {
        console.error('Error al parsear comentarios:', error);
      }
    }

    // Limpiar el textarea después de renderizar los comentarios existentes
    commentInput.value = '';
  }

  function addComment(claseId) {
    const commentInput = document.getElementById('comment-input');
    const commentsList = document.getElementById('comments-list');
    const commentText = commentInput.value.trim();

    if (commentText) {
      // Guardar el comentario en el servidor
      fetch('/api/contribuciones', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          content: commentText,
          claseId: claseId,
          tipo: 'COMENTARIO'
        })
      })
        .then(response => {
          if (response.ok) {
            const now = new Date();
            const timeString = now.toLocaleTimeString('es-ES', {
              hour: '2-digit',
              minute: '2-digit'
            });
            const dateString = now.toLocaleDateString('es-ES', {
              day: '2-digit',
              month: '2-digit',
              year: 'numeric'
            });

            const newComment = document.createElement('div');
            newComment.style.padding = '10px';
            newComment.style.borderBottom = '1px solid var(--border)';
            newComment.style.fontSize = '0.85rem';
            newComment.innerHTML = `
              <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:5px;">
                <strong style="color:var(--accent);">Tú:</strong>
                <div style="display:flex; gap:5px;">
                  <button onclick="editComment(${commentsList.children.length})" style="background:none; border:none; color:var(--accent); cursor:pointer; font-size:0.8rem;">✏️ Editar</button>
                  <button onclick="confirmDeleteComment(${commentsList.children.length})" style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:0.8rem;">🗑️ Eliminar</button>
                </div>
              </div>
              <div id="comment-text-${commentsList.children.length}">${commentText}</div>
              <div id="comment-edit-${commentsList.children.length}" style="display:none;">
                <textarea id="comment-input-${commentsList.children.length}" rows="2" style="width:100%; padding:8px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">${commentText}</textarea>
                <div style="margin-top:5px; display:flex; gap:10px;">
                  <button onclick="saveComment(${commentsList.children.length})" style="flex:1; padding:6px 12px; background:var(--accent); color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Actualizar</button>
                  <button onclick="cancelEditComment(${commentsList.children.length})" style="flex:1; padding:6px 12px; background:#64748b; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Cancelar</button>
                </div>
              </div>
              <div style="margin-top:5px;">
                <span style="color:#64748b; font-size:0.75rem;">${dateString} ${timeString}</span>
              </div>
            `;

            const noComments = commentsList.querySelector('p');
            if (noComments) {
              noComments.style.display = 'none';
            }

            commentsList.appendChild(newComment);
            commentInput.value = '';
          } else {
            alert('Error al guardar el comentario');
          }
        })
        .catch(error => {
          alert('Error al guardar el comentario: ' + error.message);
        });
    }
  }

  function editComment(index) {
    document.getElementById(`comment-text-${index}`).style.display = 'none';
    document.getElementById(`comment-edit-${index}`).style.display = 'block';
  }

  function cancelEditComment(index) {
    document.getElementById(`comment-text-${index}`).style.display = 'block';
    document.getElementById(`comment-edit-${index}`).style.display = 'none';
  }

  function saveComment(index) {
    const newCommentText = document.getElementById(`comment-input-${index}`).value.trim();
    if (newCommentText) {
      document.getElementById(`comment-text-${index}`).textContent = newCommentText;
      document.getElementById(`comment-text-${index}`).style.display = 'block';
      document.getElementById(`comment-edit-${index}`).style.display = 'none';
    }
  }

  function confirmDeleteComment(index) {
    if (confirm('¿Estás seguro de que quieres eliminar este comentario?')) {
      const commentElement = document.getElementById(`comment-text-${index}`).closest('div');
      commentElement.remove();
    }
  }

  function clearComments() {
    const commentsList = document.getElementById('comments-list');
    const commentInput = document.getElementById('comment-input');
    commentsList.innerHTML = '<p style="font-size:0.85rem; color:#64748b;">No hay comentarios nuevos.</p>';
    commentInput.value = '';
  }

  // Renderizar comentarios existentes al cargar la página
  window.addEventListener('DOMContentLoaded', function() {
    renderExistingComments();
  });
</script>