<div class="card">
  <h3 style="margin-bottom:15px;">💬 Comentarios</h3>
  <div id="comments-list" style="margin-bottom:15px;">
    <p style="font-size:0.85rem; color:#64748b;">No hay comentarios nuevos.</p>
  </div>
  <div style="margin-bottom:15px;">
    <textarea id="comment-input" placeholder="Escribe tu comentario aquí..." rows="3"
      style="width:100%; padding:10px; border:1px solid var(--border); border-radius:6px; resize:vertical; font-family:inherit;">[<% const comentarios = contributions.contribuciones.filter(c=> c.tipo == "COMENTARIO"); %>
<% comentarios.forEach((contrib, index) => { %>
        {"id":<%= contrib.id %>,"msg":"<%= contrib.content.replace(/"/g, '&quot;') %>"}<% if (index < comentarios.length - 1) { %>,<% } %>
<% }) %>]</textarea>
  </div>
  <div style="display:flex; gap:10px;">
    <button onclick="addComment(<%= claseId %>)"
      style="flex:1; padding:8px 16px; background:var(--accent); color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.9rem;">
      Publicar Comentario
    </button>
    <button onclick="clearComments()"
      style="flex:1; padding:8px 16px; background:#64748b; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.9rem;">
      Limpiar
    </button>
  </div>
</div>

<script>
  let comments = [];

  function renderExistingComments() {
    const commentInput = document.getElementById('comment-input');
    const commentsList = document.getElementById('comments-list');
    const commentText = commentInput.value.trim();

    if (commentText) {
      try {
        comments = JSON.parse(commentText);
        if (comments && comments.length > 0) {
          commentsList.innerHTML = '';

          comments.forEach((comment, index) => {
            const now = new Date();
            const timeString = now.toLocaleTimeString('es-ES', {
              hour: '2-digit',
              minute: '2-digit'
            });
            const dateString = now.toLocaleDateString('es-ES', {
              day: '2-digit',
              month: '2-digit',
              year: 'numeric'
            });

            const newComment = document.createElement('div');
            newComment.className = 'comment-item';
            newComment.style.padding = '10px';
            newComment.style.borderBottom = '1px solid var(--border)';
            newComment.style.fontSize = '0.85rem';
            newComment.innerHTML = `
              <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:5px;">
                <strong style="color:var(--accent);">Tú:</strong>
                <div style="display:flex; gap:5px;">
                  <button onclick="editComment(${comment.id})" style="background:none; border:none; color:var(--accent); cursor:pointer; font-size:0.8rem;">✏️ Editar</button>
                  <button onclick="confirmDeleteComment(${comment.id})" style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:0.8rem;">🗑️ Eliminar</button>
                </div>
              </div>
              <div id="comment-text-${comment.id}">${comment.msg}</div>
              <div id="comment-edit-${comment.id}" style="display:none;">
                <textarea id="comment-input-${comment.id}" rows="2" style="width:100%; padding:8px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">${comment.msg}</textarea>
                <div style="margin-top:5px; display:flex; gap:10px;">
                  <button onclick="saveComment(${comment.id})" style="flex:1; padding:6px 12px; background:var(--accent); color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Actualizar</button>
                  <button onclick="cancelEditComment(${comment.id})" style="flex:1; padding:6px 12px; background:#64748b; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Cancelar</button>
                </div>
              </div>
              <div style="margin-top:5px;">
                <span style="color:#64748b; font-size:0.75rem;">${dateString} ${timeString}</span>
              </div>
            `;

            commentsList.appendChild(newComment);
          });
        } else {
          commentsList.innerHTML = '<p style="font-size:0.85rem; color:#64748b;">No hay comentarios nuevos.</p>';
        }
      } catch (error) {
        console.error('Error al parsear comentarios:', error);
      }
    }

    // Limpiar el textarea después de renderizar los comentarios existentes
    commentInput.value = '';
  }

  function addComment(claseId) {
    const commentInput = document.getElementById('comment-input');
    const commentsList = document.getElementById('comments-list');
    const commentText = commentInput.value.trim();

    if (commentText) {
      // Guardar el comentario en el servidor
      fetch('/api/contribuciones', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          content: commentText,
          claseId: claseId,
          tipo: 'COMENTARIO'
        })
      })
        .then(response => {
          if (response.ok) {
            return response.json();
          } else {
            alert('Error al guardar el comentario');
          }
        })
        .then(newCommentData => {
          const now = new Date();
          const timeString = now.toLocaleTimeString('es-ES', {
            hour: '2-digit',
            minute: '2-digit'
          });
          const dateString = now.toLocaleDateString('es-ES', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric'
          });

          const newComment = document.createElement('div');
          newComment.className = 'comment-item';
          newComment.style.padding = '10px';
          newComment.style.borderBottom = '1px solid var(--border)';
          newComment.style.fontSize = '0.85rem';
          newComment.innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:5px;">
              <strong style="color:var(--accent);">Tú:</strong>
              <div style="display:flex; gap:5px;">
                <button onclick="editComment(${newCommentData.id})" style="background:none; border:none; color:var(--accent); cursor:pointer; font-size:0.8rem;">✏️ Editar</button>
                <button onclick="confirmDeleteComment(${newCommentData.id})" style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:0.8rem;">🗑️ Eliminar</button>
              </div>
            </div>
            <div id="comment-text-${newCommentData.id}">${commentText}</div>
            <div id="comment-edit-${newCommentData.id}" style="display:none;">
              <textarea id="comment-input-${newCommentData.id}" rows="2" style="width:100%; padding:8px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">${commentText}</textarea>
              <div style="margin-top:5px; display:flex; gap:10px;">
                <button onclick="saveComment(${newCommentData.id})" style="flex:1; padding:6px 12px; background:var(--accent); color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Actualizar</button>
                <button onclick="cancelEditComment(${newCommentData.id})" style="flex:1; padding:6px 12px; background:#64748b; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.8rem;">Cancelar</button>
              </div>
            </div>
            <div style="margin-top:5px;">
              <span style="color:#64748b; font-size:0.75rem;">${dateString} ${timeString}</span>
            </div>
          `;

          const noComments = commentsList.querySelector('p');
          if (noComments) {
            noComments.style.display = 'none';
          }

          commentsList.appendChild(newComment);
          commentInput.value = '';
        })
        .catch(error => {
          alert('Error al guardar el comentario: ' + error.message);
        });
    }
  }

  function editComment(commentId) {
    document.getElementById(`comment-text-${commentId}`).style.display = 'none';
    document.getElementById(`comment-edit-${commentId}`).style.display = 'block';
  }

  function cancelEditComment(commentId) {
    document.getElementById(`comment-text-${commentId}`).style.display = 'block';
    document.getElementById(`comment-edit-${commentId}`).style.display = 'none';
  }

  function saveComment(commentId) {
    const newCommentText = document.getElementById(`comment-input-${commentId}`).value.trim();

    if (newCommentText) {
      // Actualizar el comentario en el servidor
      fetch(`/api/contribuciones/${commentId}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ content: newCommentText })
      })
        .then(response => {
          if (response.ok) {
            document.getElementById(`comment-text-${commentId}`).textContent = newCommentText;
            document.getElementById(`comment-text-${commentId}`).style.display = 'block';
            document.getElementById(`comment-edit-${commentId}`).style.display = 'none';
          } else {
            alert('Error al actualizar el comentario');
          }
        })
        .catch(error => {
          alert('Error al actualizar el comentario: ' + error.message);
        });
    }
  }

  function confirmDeleteComment(commentId) {
    if (confirm('¿Estás seguro de que quieres eliminar este comentario?')) {
      // Eliminar el comentario del servidor
      fetch(`/api/contribuciones/${commentId}`, {
        method: 'DELETE'
      })
        .then(response => {
          if (response.ok) {
            // Eliminar el elemento completo del DOM usando la clase 'comment-item'
            const commentElement = document.getElementById(`comment-text-${commentId}`).closest('.comment-item');
            if (commentElement) {
              commentElement.remove();
            }
          } else {
            alert('Error al eliminar el comentario');
          }
        })
        .catch(error => {
          alert('Error al eliminar el comentario: ' + error.message);
        });
    }
  }

  function clearComments() {
    const commentsList = document.getElementById('comments-list');
    const commentInput = document.getElementById('comment-input');
    commentsList.innerHTML = '<p style="font-size:0.85rem; color:#64748b;">No hay comentarios nuevos.</p>';
    commentInput.value = '';
  }

  // Renderizar comentarios existentes al cargar la página
  window.addEventListener('DOMContentLoaded', function() {
    renderExistingComments();
  });
</script>