<div class="page-content">
  <div class="breadcrumb">
    <a href="/uni" target="_parent">🏠 Mis Materias</a> &nbsp; | &nbsp;
    <a href="/uni/materia/<%= ejercicios[0].materiaId %>" target="_parent">
      <%= ejercicios[0].materiaId %>: Nombre de materia
    </a> &nbsp; | &nbsp;
    <span style="color:#3b82f5;">
      <%= clase.content %>
    </span>
  </div>

  <h1 style="margin-top:20px;">
    <%= clase.content %>
  </h1>



  <!-- SECCIÓN DE CONTENIDO PRINCIPAL -->
  <div style="display: flex; gap: 30px;">
    <!-- Columna Izquierda: Resumen Teórico -->
    <div style="flex: 2;">
      <div class="card" style="max-height: 600px; overflow-y: auto;">
        <div id="resumen-teoria-container">
          <%= clase.content %>
        </div>

        <div id="resumen-teoria-editado" style="display: none;">
          <div id="resumen-teoria-editado-content"></div>
        </div>

        <div id="resumen-teoria-botones" style="display: none;">
          <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.9rem;"
              onclick="cancelVisualization()">Cancelar</button>
            <button class="btn btn-primary" style="padding: 8px 16px; font-size: 0.9rem;"
              onclick="confirmarGuardar()">Guardar cambios</button>
          </div>
        </div>
      </div>


      <div class="card">
        <h2 style="margin-bottom:15px;">📁 Material Descargable</h2>
        <% contributions.contribuciones.filter(c=> c.tipo == "FILE").forEach(contrib => { %>
          <div class="list-item">
            <span>
              <%= contrib.content %>
            </span>
            <button class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Descargar</button>
          </div>
          <% }) %>
      </div>

      <div class="card">
        <h2 style="margin-bottom:15px;">📤 Entrega de Tarea</h2>
        <form action="#" onsubmit="alert('Tarea enviada!'); return false;"
          style="display:flex; flex-direction:row; align-items:center; gap:10px;">
          <input type="file" style="border:none; padding:0; font-size:0.8rem;">
          <button type="submit" class="btn btn-primary">Enviar</button>
        </form>
      </div>

      <div class="card" style="margin-top: 20px;">
        <h2 style="margin-bottom:15px;">🔍 Visualización de Contenido</h2>
        <textarea id="visualizer-input" placeholder="Pega aquí el contenido o código a visualizar..."
          onfocus="document.getElementById('visualizer-input').scrollIntoView({ behavior: 'smooth', block: 'center' });"
          style="width: 100%; height: 80vh; padding: 10px; border: 1px solid var(--border); border-radius: 6px; resize: vertical; font-family: monospace;"><%= clase.content %></textarea>
        <div style="margin-top: 15px;">
          <button id="visualizer-btn" onclick="visualizeContent()" class="btn btn-primary"
            style="width: 100%;">Visualizar</button>
        </div>
      </div>
    </div>

    <!-- Columna Derecha -->
    <div style="flex: 1;">
      <%- include('../partials/novedades', { news: news }); %>
      <div class="card" id="indice-container">
        <div style="display: flex; justify-content: center; gap: 20px; margin-top: 0px;">
          <% if (clase.prevClass) {%>
            <a href="/uni/materia/<%= clase.prevClass.materiaId %>/clase/<%= clase.prevClass.id %>"
              class="btn btn-secondary" style="font-size: 0.8rem; padding: 5px 10px;">&larr; Clase
              Anterior</a>
            <% } %>
              <% if (clase.nextClass) {%>
                <a href="/uni/materia/<%= clase.nextClass.materiaId %>/clase/<%= clase.nextClass.id %>"
                  class="btn btn-secondary" style="font-size: 0.8rem; padding: 5px 10px;">Próxima Clase
                  &rarr;</a>
                <% } %>
        </div>
      </div>
      <%- include('../partials/indice-contenido'); %>

      <%- include('../partials/banco-ejercicios', { ejercicios: ejercicios }); %>
        <div class="card">
          <h3 style="margin-bottom:15px;">🎵 Audio de Apoyo</h3>
          <% contributions.contribuciones.filter(c=> c.tipo == "AUDIO").forEach(contrib => { %>
            <div class="audio-container list-item">
              <p>
                <%= contrib.content %>
              </p>
              <div class="play-control">
                <div class="play-button" onclick="toggleAudio('audio1', this)" style="cursor: default;">▶️</div>
                <div id="controls-audio1" class="controls-wrap" style="display: none;">
                  <audio id="audio1" style="display: none;">
                    <source src="aaa.mp3" type="audio/mpeg">
                    Tu navegador no soporta el elemento de audio.
                  </audio>
                </div>
              </div>
            </div>
            <% }) %>
        </div>


      <%- include('../partials/comentarios', { contributions: contributions }); %>
        <div class="card" style="margin-top:30px;">
          <h3 style="margin-bottom:15px;">🎥 Vídeos Relacionable</h3>
          <div id="video-grid" style="display: flex; flex-wrap: wrap; gap: 15px;">
            <% contributions.contribuciones.filter(c=> c.tipo == "YOUTUBE").forEach(contrib => { %>
              <div class="video-thumb" onclick="playVideo('rzYDWIQh2r4')"
                style="cursor:pointer; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; background: #000; width: 200px;">
                <img src="https://img.youtube.com/vi/rzYDWIQh2r4/mqdefault.jpg" style="width:100%; display:block;">
                <div style="padding: 8px; font-size: 0.8rem; color: #ffffff; text-align:center;">
                  <%= contrib.content %>
                </div>
              </div>
              <% }) %>
          </div>
        </div>

        <div id="main-player-container" class="card"
          style="display:none; padding:0; overflow:hidden; border:none; background:#000; position:fixed; top:50%; left:20%; transform: translateY(-50%); width:60%; height:80vh; z-index:9999;">
          <div style="position: relative; padding-bottom: 56.25%; height: 0;">
            <iframe id="yt-player" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;" src=""
              frameborder="0" allowfullscreen></iframe>
          </div>
          <div
            style="padding:15px; text-align:right; background:#222; position:absolute; bottom:0; left:0; width:100%; flex-shrink: 0;">
            <button class="btn btn-primary" onclick="closePlayer()" style="font-size:0.8rem; color:white;">Cerrar
              Vídeo</button>
          </div>
        </div>
    </div>
  </div>





  <script>
    let indiceAutoCloseTimer;

    function playVideo(id) {
      const container = document.getElementById('main-player-container');
      const player = document.getElementById('yt-player');
      player.src = "https://www.youtube.com/embed/" + id + "?autoplay=1";
      container.style.display = 'block';
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    }

    function closePlayer() {
      document.getElementById('main-player-container').style.display = 'none';
      document.getElementById('yt-player').src = '';
    }

    function visualizeContent() {
      const input = document.getElementById('visualizer-input');
      const editadoContent = document.getElementById('resumen-teoria-editado-content');
      const originalContainer = document.getElementById('resumen-teoria-container');
      const editadoContainer = document.getElementById('resumen-teoria-editado');
      const botonesContainer = document.getElementById('resumen-teoria-botones');
      const visualizerBtn = document.getElementById('visualizer-btn');

      if (input && editadoContent && originalContainer && editadoContainer && botonesContainer && visualizerBtn) {
        editadoContent.textContent = input.value;
        originalContainer.style.display = 'none';
        editadoContainer.style.display = 'block';
        botonesContainer.style.display = 'block';

        const h1 = document.querySelector('h1');
        h1.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    function cancelVisualization() {
      const originalContainer = document.getElementById('resumen-teoria-container');
      const editadoContainer = document.getElementById('resumen-teoria-editado');
      const botonesContainer = document.getElementById('resumen-teoria-botones');
      const visualizerBtn = document.getElementById('visualizer-btn');

      if (originalContainer && editadoContainer && botonesContainer && visualizerBtn) {
        originalContainer.style.display = 'block';
        editadoContainer.style.display = 'none';
        botonesContainer.style.display = 'none';
        visualizerBtn.textContent = 'Visualizar';
        visualizerBtn.onclick = visualizeContent;
      }
    }

    function confirmarGuardar() {
      if (confirm('¿Estás seguro? Los cambios serán irreversibles.')) {
        const editadoContent = document.getElementById('resumen-teoria-editado-content').textContent;
        const claseId = <%= clase.id %>;

        fetch(`/api/clases/${claseId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ content: editadoContent })
        })
          .then(response => {
            if (response.ok) {
              alert('Cambios guardados correctamente');
            } else {
              alert('Error al guardar los cambios');
            }
          })
          .catch(error => {
            alert('Error al guardar los cambios: ' + error.message);
          });
      }
    }

    function highlightActiveSection() {
      const activeSection = localStorage.getItem('activeSection');
      if (activeSection) {
        const section = document.getElementById(activeSection);
        const container = document.getElementById('resumen-teoria-container');
        if (section && container) {
          const sectionTop = section.offsetTop - container.offsetTop;
          container.scrollTop = sectionTop;
          const allLinks = document.querySelectorAll('.nav-link');
          allLinks.forEach(link => link.classList.remove('active'));
          const activeLink = document.querySelector(`.nav-link[href="#${activeSection}"]`);
          if (activeLink) {
            activeLink.classList.add('active');
          }
          updateIndiceButtons();
        }
      }

      function updateIndiceButtons() {
        const indiceList = document.getElementById('indice-list');
        const toggleIcon = document.getElementById('indice-toggle-icon');
        const hideButton = document.getElementById('hide-indice-btn');
        const header = document.getElementById('indice-header');
        if (indiceList.style.maxHeight === '0px') {
          toggleIcon.textContent = '+';
          hideButton.textContent = 'Mostrar Índice';
          header.style.marginBottom = '0px';
        } else {
          toggleIcon.textContent = '−';
          hideButton.textContent = 'Ocultar Índice';
          header.style.marginBottom = '15px';
        }
      }
    }

    window.addEventListener('load', () => {
      const indiceList = document.getElementById('indice-list');
      const hideButton = document.getElementById('hide-indice-btn');
      if (indiceList.style.maxHeight === '0px') {
        hideButton.textContent = 'Mostrar Índice';
      } else {
        hideButton.textContent = 'Ocultar Índice';
      }
      highlightActiveSection();
    });

  </script>
</div>