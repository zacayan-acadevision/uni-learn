                <div style="position: relative; padding-bottom: 56.25%; height: 0;">
                    <iframe id="yt-player" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                        src="" frameborder="0" allowfullscreen></iframe>
