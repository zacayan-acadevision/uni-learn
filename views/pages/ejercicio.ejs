<div class="page-content">
  <div class="breadcrumb">
    <a href="/uni" target="_parent">🏠 Mis Materias</a> &nbsp; | &nbsp;
    <a href="/uni/materia/<%= ejercicios[0].materiaId %>" target="_parent"><%= ejercicios[0].materiaId %>: Nombre de materia</a> &nbsp; | &nbsp;
    <span style="color:#3b82f5;">Ejercicio</span>
  </div>

  <h1 style="margin-top:20px;">Ejercicio</h1>



  <!-- SECCIÓN DE CONTENIDO PRINCIPAL -->
  <div style="display: flex; gap: 30px;">
    <!-- Columna Izquierda: Resumen Teórico -->
    <div style="flex: 2;">
      <div class="card" style="max-height: 600px; overflow-y: auto;">
        <div id="resumen-teoria-container">
          <%= ejercicio.content %>
        </div>

        <div id="resumen-teoria-editado" style="display: none;">
          <div id="resumen-teoria-editado-content"></div>
        </div>

        <div id="resumen-teoria-botones" style="display: none;">
          <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.9rem;" onclick="cancelVisualization()">Cancelar</button>
            <button class="btn btn-primary" style="padding: 8px 16px; font-size: 0.9rem;" onclick="confirmarGuardar()">Guardar cambios</button>
          </div>
        </div>
      </div>


      <div class="card">
        <h2 style="margin-bottom:15px;">📤 Entrega de Tarea</h2>
        <form action="#" onsubmit="alert('Tarea enviada!'); return false;" style="display:flex; flex-direction:row; align-items:center; gap:10px;">
          <input type="file" style="border:none; padding:0; font-size:0.8rem;">
          <button type="submit" class="btn btn-primary">Enviar</button>
        </form>
      </div>

      <div class="card" style="margin-top: 20px;">
        <h2 style="margin-bottom:15px;">🔍 Visualización de Contenido</h2>
        <textarea id="visualizer-input" placeholder="Pega aquí el contenido o código a visualizar..." onfocus="document.getElementById('visualizer-input').scrollIntoView({ behavior: 'smooth', block: 'center' });" style="width: 100%; height: 80vh; padding: 10px; border: 1px solid var(--border); border-radius: 6px; resize: vertical; font-family: monospace;"><%= ejercicio.content %></textarea>
        <div style="margin-top: 15px;">
          <button id="visualizer-btn" onclick="visualizeContent()" class="btn btn-primary" style="width: 100%;">Visualizar</button>
        </div>
      </div>
    </div>

    <!-- Columna Derecha -->
    <div style="flex: 1;">
      <%- include('../partials/novedades', { news: news }); %>
      <div class="card" id="indice-container">
        <div style="display: flex; justify-content: center; gap: 20px; margin-top: 0px;">
          <% if (ejercicio.prevEjercicio) {%>
          <a href="/uni/materia/<%= ejercicio.prevEjercicio.materiaId %>/ejercicio/<%= ejercicio.prevEjercicio.id %>" class="btn btn-secondary" style="font-size: 0.8rem; padding: 5px 10px;">&larr; Ejercicio
            Anterior</a>
          <% } %>
          <% if (ejercicio.nextEjercicio) {%>
          <a href="/uni/materia/<%= ejercicio.nextEjercicio.materiaId %>/ejercicio/<%= ejercicio.nextEjercicio.id %>" class="btn btn-secondary" style="font-size: 0.8rem; padding: 5px 10px;">Próximo Ejercicio
            &rarr;</a>
          <% } %>
        </div>
      </div>
      <%- include('../partials/indice-contenido'); %>
      <%- include('../partials/banco-ejercicios', { ejercicios: ejercicios }); %>
      <%- include('../partials/clases-visualizacion-no-crud', { clases: clases }); %>


     




    </div>
  </div>





  <script>
    function visualizeContent() {
      const input = document.getElementById('visualizer-input');
      const editadoContent = document.getElementById('resumen-teoria-editado-content');
      const originalContainer = document.getElementById('resumen-teoria-container');
      const editadoContainer = document.getElementById('resumen-teoria-editado');
      const botonesContainer = document.getElementById('resumen-teoria-botones');
      const visualizerBtn = document.getElementById('visualizer-btn');

      if (input && editadoContent && originalContainer && editadoContainer && botonesContainer && visualizerBtn) {
        editadoContent.textContent = input.value;
        originalContainer.style.display = 'none';
        editadoContainer.style.display = 'block';
        botonesContainer.style.display = 'block';

        const h1 = document.querySelector('h1');
        h1.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    function cancelVisualization() {
      const originalContainer = document.getElementById('resumen-teoria-container');
      const editadoContainer = document.getElementById('resumen-teoria-editado');
      const botonesContainer = document.getElementById('resumen-teoria-botones');
      const visualizerBtn = document.getElementById('visualizer-btn');

      if (originalContainer && editadoContainer && botonesContainer && visualizerBtn) {
        originalContainer.style.display = 'block';
        editadoContainer.style.display = 'none';
        botonesContainer.style.display = 'none';
        visualizerBtn.textContent = 'Visualizar';
        visualizerBtn.onclick = visualizeContent;
      }
    }

    function confirmarGuardar() {
      if (confirm('¿Estás seguro? Los cambios serán irreversibles.')) {
        const editadoContent = document.getElementById('resumen-teoria-editado-content').textContent;
        const ejercicioId = <%= ejercicio.id %>;

        fetch(`/api/ejercicios/${ejercicioId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ content: editadoContent })
        })
        .then(response => {
          if (response.ok) {
            alert('Cambios guardados correctamente');
          } else {
            alert('Error al guardar los cambios');
          }
        })
        .catch(error => {
          alert('Error al guardar los cambios: ' + error.message);
        });
      }
    }
  </script>
</div>