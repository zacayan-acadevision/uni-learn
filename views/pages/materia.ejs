<div class="page-content">
  <div class="breadcrumb">
    <a href="/uni" target="mainFrame">← Volver a Materias</a> &nbsp; | &nbsp;
    <span><%= clases.id %>: <%= clases.content %></span>
  </div>

  <h1 style="margin-top:20px;">Detalle de la Asignatura</h1>

  <!-- Buscador dinámico -->
  <div class="search-box">
    <input type="text" id="buscadorClases" placeholder="🔍 Buscar clase (ej: 'Límites' o 'Derivadas')..." onkeyup="filtrarClases()">
  </div>

  <div style="display: flex; gap: 30px;">
    <!-- Columna Izquierda: Clases y Ejercicios -->
    <div style="flex: 2;">
      <div class="card">
        <h2 style="margin-bottom:15px;">Clases Disponibles</h2>
        <div id="listaClases">

          <% clases.clases.forEach(clase => { %>
          <div class="list-item" data-n="clase 1 limites">
            <span class="item-text"><strong style="color:var(--primary)">Clase 1:</strong> <%= clase.content %></span>
            <!-- target="_self" es el comportamiento natural para navegar dentro del mismo iframe -->
            <a href="/uni/materia/<%= clases.id%>/clase/<%= clase.id %>" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver Clase</a>
          </div>
          <% }) %>

          <!-- Formulario para crear clase -->
          <div id="formularioCrearClase" style="display:none; margin-top:10px; padding:15px; background:#f8fafc; border-radius:8px; border:1px solid #e2e8f0;">
            <input type="text" id="tituloNuevaClase" placeholder="Título de la nueva clase" style="width:100%; padding:10px; margin-bottom:10px; border:1px solid #cbd5e1; border-radius:4px;">
            <div style="display:flex; gap:10px;">
              <button onclick="confirmarCrearClase()" class="btn btn-primary" style="padding:8px 16px; font-size:0.85rem;">Confirmar</button>
              <button onclick="cancelarCrearClase()" class="btn btn-secondary" style="padding:8px 16px; font-size:0.85rem;">Cancelar</button>
            </div>
          </div>

          <div class="list-item" id="crearClaseItem" data-n="clase nueva">
            <span class="item-text"><strong style="color:var(--primary)">Crear nueva clase</strong></span>
            <button onclick="mostrarFormularioCrearClase()" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Crear</button>
          </div>
        </div>
      </div>

      <div class="card">
        <h2 style="margin-bottom:15px;">Banco de Ejercicios</h2>
        <% ejercicios.forEach(ejercicio=> { %>
        <div class="list-item">
          <span>Ejercicio <%= ejercicio.id %>: <%= ejercicio.content %></span>
          <a href="ejercicio_page.html" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver
            Ejercicio</a>
        </div>
        <% }) %>
        <div class="list-item">
          <span>Ejercicio 1.2: Indeterminación 0/0</span>
          <a href="ejercicio_page.html" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver Ejercicio</a>
        </div>
      </div>
    </div>

    <!-- Columna Derecha -->
    <div style="flex: 1;">
      <div class="card">
        <h3 style="margin-bottom:10px;">📢 Novedades</h3>
        <p style="font-size: 0.85rem; color: #64748b;">• Nuevo PDF disponible.</p>
      </div>
      <div class="card">
        <h3 style="margin-bottom:10px;">💬 Comentarios</h3>
        <div style="font-size: 0.85rem; color: #475565;">
          <strong style="display:block; margin-bottom:5px;">Prof. García:</strong>
          No olviden repasar la guía.
        </div>
      </div>
    </div>
  </div>

  <script>
    function filtrarClases() {
      const input = document.getElementById('buscadorClases');
      const filter = input.value.toLowerCase();
      const items = document.querySelectorAll('#listaClases .list-item');

      items.forEach(item => {
        const text = item.getAttribute('data-n');
        if (text && text.includes(filter)) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });
    }

    function mostrarFormularioCrearClase() {
      const formulario = document.getElementById('formularioCrearClase');
      const crearItem = document.getElementById('crearClaseItem');
      formulario.style.display = 'block';
      crearItem.style.display = 'none';
    }

    function cancelarCrearClase() {
      const formulario = document.getElementById('formularioCrearClase');
      const crearItem = document.getElementById('crearClaseItem');
      formulario.style.display = 'none';
      crearItem.style.display = 'flex';
      document.getElementById('tituloNuevaClase').value = '';
    }

    function confirmarCrearClase() {
      const titulo = document.getElementById('tituloNuevaClase').value;
      const materiaId = <%= clases.id %>;

      if (titulo.trim() !== '') {
        // Hacer llamada al backend para crear la clase
        fetch('/api/clases', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            content: titulo,
            materiaId: materiaId
          })
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Error al crear la clase');
          }
          return response.json();
        })
        .then(nuevaClase => {
          const listaClases = document.getElementById('listaClases');
          const formulario = document.getElementById('formularioCrearClase');

          // Crear nuevo ítem igual que los demás
          const nuevoItem = document.createElement('div');
          nuevoItem.className = 'list-item';
          nuevoItem.setAttribute('data-n', titulo.toLowerCase());
          nuevoItem.innerHTML = `
            <span class="item-text"><strong style="color:var(--primary)">Clase ${nuevaClase.id}:</strong> ${nuevaClase.content}</span>
            <a href="#" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver Clase</a>
          `;

          // Insertar antes del formulario
          listaClases.insertBefore(nuevoItem, formulario);

          // Actualizar el href dinámicamente
          const nuevoLink = nuevoItem.querySelector('a');
          nuevoLink.href = `/uni/materia/${materiaId}/clase/${nuevaClase.id}`;

          // Ocultar formulario y mostrar el ítem de crear
          cancelarCrearClase();
        })
        .catch(error => {
          alert('Error al crear la clase: ' + error.message);
        });
      } else {
        alert('Por favor ingresa un título para la clase');
      }
    }
  </script>
</div>