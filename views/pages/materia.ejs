<div class="page-content">
  <div class="breadcrumb">
    <a href="/uni" target="mainFrame">← Volver a Materias</a> &nbsp; | &nbsp;
    <span><%= clases.id %>: <%= clases.content %></span>
  </div>

  <h1 style="margin-top:20px;">Detalle de la Asignatura</h1>

  <!-- Buscador dinámico -->
  <div class="search-box">
    <input type="text" id="buscadorClases" placeholder="🔍 Buscar clase (ej: 'Límites' o 'Derivadas')..." onkeyup="filtrarClases()">
  </div>

  <div style="display: flex; gap: 30px;">
    <!-- Columna Izquierda: Clases y Ejercicios -->
    <div style="flex: 2;">
      <%- include('../partials/clases-disponibles', { clases: clases }); %>

      <%- include('../partials/banco-ejercicios', { ejercicios: ejercicios }); %>
    </div>

    <!-- Columna Derecha -->
    <div style="flex: 1;">
      
      <%- include('../partials/novedades', { news: news }); %>


      <div class="card">
        <h3 style="margin-bottom:10px;">💬 Comentarios</h3>
        <div style="font-size: 0.85rem; color: #475565;">
          <strong style="display:block; margin-bottom:5px;">Prof. García:</strong>
          No olviden repasar la guía.
        </div>
      </div>
    </div>
  </div>

  <script>
    function filtrarClases() {
      const input = document.getElementById('buscadorClases');
      const filter = input.value.toLowerCase();
      const items = document.querySelectorAll('#listaClases .list-item');

      items.forEach(item => {
        const textElement = item.querySelector('.item-text');
        const text = textElement ? textElement.textContent.toLowerCase() : '';
        if (text.includes(filter)) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });
    }

    function toggleCard(contentId, button) {
      const content = document.getElementById(contentId);
      const icon = button.querySelector('span');
      if (content.style.maxHeight === '0px') {
        content.style.maxHeight = '1000px';
        content.style.marginTop = '15px';
        icon.textContent = '−';
      } else {
        content.style.maxHeight = '0px';
        content.style.marginTop = '0px';
        icon.textContent = '+';
      }
    }
  </script>
</div>