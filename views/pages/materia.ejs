<div class="page-content">
  <div class="breadcrumb">
    <a href="/uni" target="mainFrame">← Volver a Materias</a> &nbsp; | &nbsp;
    <span><%= clases.id %>: <%= clases.content %></span>
  </div>

  <h1 style="margin-top:20px;">Detalle de la Asignatura</h1>

  <!-- Buscador dinámico -->
  <div class="search-box">
    <input type="text" id="buscadorClases" placeholder="🔍 Buscar clase (ej: 'Límites' o 'Derivadas')..." onkeyup="filtrarClases()">
  </div>

  <div style="display: flex; gap: 30px;">
    <!-- Columna Izquierda: Clases y Ejercicios -->
    <div style="flex: 2;">
      <div class="card">
        <h2 style="margin-bottom:15px;">Clases Disponibles</h2>
        <div id="listaClases">

          <% clases.clases.forEach(clase => { %>
          <div class="list-item" data-n="clase 1 limites">
            <span class="item-text"><strong style="color:var(--primary)">Clase 1:</strong> <%= clase.content %></span>
            <!-- target="_self" es el comportamiento natural para navegar dentro del mismo iframe -->
            <a href="/uni/materia/<%= clases.id%>/clase/<%= clase.id %>" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver Clase</a>
          </div>
          <% }) %>

          <div class="list-item" data-n="clase nueva">
            <span class="item-text"><strong style="color:var(--primary)">Crear nueva clase</strong></span>
            <a href="new_page.html" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Crear</a>
          </div>
        </div>
      </div>

      <div class="card">
        <h2 style="margin-bottom:15px;">Banco de Ejercicios</h2>
        <% ejercicios.forEach(ejercicio=> { %>
        <div class="list-item">
          <span>Ejercicio <%= ejercicio.id %>: <%= ejercicio.content %></span>
          <a href="ejercicio_page.html" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver
            Ejercicio</a>
        </div>
        <% }) %>
        <div class="list-item">
          <span>Ejercicio 1.2: Indeterminación 0/0</span>
          <a href="ejercicio_page.html" target="_self" class="btn btn-primary" style="padding:5px 10px; font-size:0.8rem;">Ver Ejercicio</a>
        </div>
      </div>
    </div>

    <!-- Columna Derecha -->
    <div style="flex: 1;">
      <div class="card">
        <h3 style="margin-bottom:10px;">📢 Novedades</h3>
        <p style="font-size: 0.85rem; color: #64748b;">• Nuevo PDF disponible.</p>
      </div>
      <div class="card">
        <h3 style="margin-bottom:10px;">💬 Comentarios</h3>
        <div style="font-size: 0.85rem; color: #475565;">
          <strong style="display:block; margin-bottom:5px;">Prof. García:</strong>
          No olviden repasar la guía.
        </div>
      </div>
    </div>
  </div>

  <script>
    function filtrarClases() {
      const input = document.getElementById('buscadorClases');
      const filter = input.value.toLowerCase();
      const items = document.querySelectorAll('#listaClases .list-item');

      items.forEach(item => {
        const text = item.getAttribute('data-n');
        if (text && text.includes(filter)) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });
    }
  </script>
</div>