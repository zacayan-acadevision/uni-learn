<h1 id="title">Editar Clase</h1>
<form action="/admin/clases/<%= clase.id %>" method="POST">
  <label for="content">Contenido:</label>
  <textarea name="content" id="content"><%= clase.content %></textarea>
  <button type="submit">Guardar</button>
</form>
<form action="/admin/clases/<%= clase.id %>/delete" method="POST" style="display: inline;">
  <button type="submit" style="color: red; background: none; border: 1px solid red; padding: 5px 10px; cursor: pointer; margin-left: 10px;">Eliminar</button>
</form>
<a href="/admin">Volver</a>
<hr>
<a href="/admin/clase/<%= clase.id %>/contribuciones">Contribuciones</a>

