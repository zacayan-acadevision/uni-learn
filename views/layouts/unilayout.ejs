<!DOCTYPE html>
<html lang="es">
<base href="/">

<head>
  <meta charset="UTF-8">
  <title>EduPlatform | Core</title>
  <link rel="stylesheet" href="style.css">
</head>

<body style="margin:0; overflow:hidden;">
  <div class="app-container">
    <!-- Sidebar con navegación que controla el iframe -->
    <aside id="sidebar">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h2 style="text-align:left; margin:0; color:#3b82f6; flex-grow:1;">UNI-LEARN</h2>
        <button id="toggleSidebar" style="background:none; border:none; color:#3b82f6; cursor:pointer; font-size:1.5rem; padding:0 5px;">↔️</button>
      </div>
      <nav id="mainNav">
        <ul style="list-style:none; padding:0;">
          <li style="margin-bottom:10px;"><a href="/uni" class="nav-link" style="color:#cbd5e0; text-decoration:none; display:block; padding:12px 15px;"><span class="nav-icon">🏠</span><span class="nav-text">Mis Materias</span></a></li>
          <li style="padding:12px 15px; display:block; color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:1px;"><span class="nav-text">Plataforma Académica</span></li>
          <li style="margin-bottom:10px;"><a href="view_novedades.html" class="nav-link" style="color:#cbd5e0; text-decoration:none; display:block; padding:12px 15px;"><span class="nav-icon">📢</span><span class="nav-text">Novedades</span></a></li>
          <li style="margin-bottom:10px;"><a href="view_admin.html" class="nav-link" style="color:#cbd5e0; text-decoration:none; display:block; padding:12px 15px;"><span class="nav-icon">⚙️</span><span class="nav-text">Administración</span></a></li>
        </ul>
      </nav>
    </aside>

    <!-- Área de contenido dinámico (Iframe) -->
    <main>
      <%- body %>
    </main>
  </div>

  <script>
    // Seleccionamos el iframe y todos los enlaces del menú
    const iframe = document.getElementById('mainFrame');
    // const navLinks = document.querySelectorAll('.nav-link');
    const sidebar = document.getElementById('sidebar');
    const toggleBtn = document.getElementById('toggleSidebar');

    // Función para colapsar/expandir el sidebar
    toggleBtn.addEventListener('click', () => {
      sidebar.classList.toggle('collapsed');
    });

    // Función para refrescar el contenido de forma forzada vía JS
    function refreshIframe(url) {
      // Añadimos un parámetro único (timestamp) para evitar que el navegador use la caché
      const separator = url.includes('?') ? '&' : '?';
      const freshUrl = url + separator + 't=' + new
      Date().getTime();

      console.log("Navegando a:", freshUrl);
      iframe.src = freshUrl;
    }

    // Asignamos el evento click a cada enlace para controlar la carga vía JS
    // navLinks.forEach(link => {
    //   link.addEventListener('click', function(event) {
    //     // Prevenimos la navegación por defecto del <a> para que nuestro script tome el control
    //     event.preventDefault();

    //     const targetUrl = this.getAttribute('href');
    //     refreshIframe(targetUrl);
    //   });
    // });
  </script>
</body>

</html>